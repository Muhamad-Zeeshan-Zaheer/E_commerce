<div class="text-end me-2 mt-3 mb-3">
  <%= link_to "New Item", new_item_path, class: "btn btn-success" %>
</div>


<table class="table">
  <thead>
    <tr>
      <th scope="col">Name</th>
      <th scope="col">Description</th>
      <th scope="col">Price</th>
    </tr>
  </thead>
  <tbody>
  <%@items.each do |item|%>
    <tr>
      <td>item.name</td>
      <td>item.descripiton</td>
      <td>item.price</td>
    </tr>
  <%end%>  
  </tbody>
</table>